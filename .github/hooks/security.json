{
  "hooks": [
    {
      "event": "sessionStart",
      "run": "echo \"[$(date -u +\"%Y-%m-%dT%H:%M:%SZ\")] Agent session started\" >> /tmp/agent-sessions.log"
    },
    {
      "event": "preToolUse",
      "run": "echo \"[$(date -u +\"%Y-%m-%dT%H:%M:%SZ\")] Tool executed: $TOOL_NAME\" >> /tmp/tool-executions.log"
    }
  ]
}
